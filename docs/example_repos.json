      ],
      "elf_glob": "build/debug/High-Altitude-CC.elf",
      "flash_image_glob": "build/debug/High-Altitude-CC.elf",
      "checkout_subdir": ".",
      "timeout_seconds": 1200,
      "env": {},
      "rtt_symbol": "_SEGGER_RTT"
    }
  },
